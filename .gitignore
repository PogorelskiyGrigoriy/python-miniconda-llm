# --- Python & Environment ---
# Ignore the local Conda environment seen in your file tree
.conda/
# Ignore Python bytecode
__pycache__/
*.py[cod]

# --- Project Specific Build Files ---
# Ignore the egg-info folder generated by 'pip install -e .'
car_analysis.egg-info/

# --- Data & Logs ---
# Ignore all data files, but keep the folder structure via .gitkeep
data/raw/*
data/processed/*
data/interim/*
!data/**/.gitkeep

# Ignore log files
logs/*.log
logs/

# --- Secrets & Jupyter Noise ---
# NEVER commit your credentials
.env

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- Models ---
models/